FROM postgis/postgis:16-3.5

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git \
        build-essential \
        postgresql-server-dev-16 && \
    rm -rf /var/lib/apt/lists/*

RUN cd /tmp && \
    git clone --branch v0.8.0 https://github.com/pgvector/pgvector.git && \
    cd pgvector && \
    make && \
    make install && \
    cd /tmp && \
    rm -rf pgvector
